{
  "version": 4,
  "configurations": [
    {
      "name": "Win64",
      "intelliSenseMode": "windows-msvc-x64",
      "cppStandard": "c++17",
      "cStandard": "c17",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/source",
        "${workspaceFolder}"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/include",
          "${workspaceFolder}/source",
          "${workspaceFolder}"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
